{
  "metadata": [
    {
      "src": [
        {
          "files": ["apiref/bin/publish/RedPdf.dll"]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": ["**/*.{md,yml}"],
        "exclude": ["_site/**", "obj/**", "apiref/**", "templates/**"]
      }
    ],
    "resource": [
      {
        "files": ["logo.svg"]
      }
    ],
    "output": "_site",
    "template": ["default", "modern", "templates/redpdf"],
    "globalMetadata": {
      "_appName": "RedPdf",
      "_appTitle": "RedPdf — HTML to PDF for .NET",
      "_appFooter": "© 2026 Mercuryong. RedPdf is a commercial library with a free Community tier.",
      "_appLogoPath": "logo.svg",
      "_appFaviconPath": "logo.svg",
      "_enableSearch": true,
      "pdf": false
    }
  }
}
